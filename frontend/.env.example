# Backend base URL
VITE_API_BASE_URL=http://localhost:8000

# Product name shown in the UI (navbar, auth pages, document title)
VITE_APP_NAME=MysticAuth

# ---------------------------- Error Monitoring ----------------------------
# Optional. Sentry-protocol DSN for the frontend (works with Sentry itself,
# or a self-hosted Sentry-SDK-compatible server, e.g. Bugsink's project DSN
# — see docs/error-monitoring/overview.md). Leave blank to disable entirely — no
# Sentry SDK call is ever made when unset.
VITE_SENTRY_DSN=

# Optional. Tag reported alongside every event (e.g. "production").
# Falls back to Vite's own MODE ("development"/"production") if unset.
VITE_SENTRY_ENVIRONMENT=