# Only needed if running the frontend locally with `npm run dev` (outside
# Docker). Under `docker compose up`, the root .env's VITE_* values are used
# instead — this file is ignored there, no need to fill it in.

# Backend base URL
VITE_API_BASE_URL=http://localhost:8000

# Product name shown in the UI (navbar, auth pages, document title)
VITE_APP_NAME=MysticAuth

# ---------------------------- Error Monitoring ----------------------------
# Leave blank to disable. See docs/mystic_auth/error-monitoring/overview.md.
VITE_SENTRY_DSN=

# Optional tag shown on every reported error (e.g. "production").
# Falls back to Vite's MODE if unset.
VITE_SENTRY_ENVIRONMENT=
