# ---------------------------- Python / Backend ----------------------------
# **/ prefix (not just a bare "__pycache__/") is required for these to match
# at any depth, not just directly under the build context root — verified by
# building the image and finding real __pycache__ directories nested under
# backend/app/**/ still present without it, despite the bare pattern looking
# like it should already cover them.
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.sqlite3
*.db
*.log
# backend/logs/ — rotated access-log files (backend/app/logging/logging_config.py
# creates this directory on import and writes real request data to it: paths,
# timestamps, correlation IDs). `*.log` above only matches files ending in
# exactly ".log" — the rotated siblings TimedRotatingFileHandler creates
# (access.log.2026-07-19, etc.) don't match that pattern and were previously
# getting copied straight into the built image by `COPY backend/ .` (the
# .dockerignore build context is the repo root, so the path must be written
# relative to that, not to backend/'s own directory), baking a snapshot of
# whoever's local dev traffic happened to be sitting in that directory at
# build time into every image — a real privacy leak and non-reproducible-
# build bug, not just wasted space (measured at 23MB in one case).
backend/logs/
**/*.egg-info/
dist/
build/
**/.pytest_cache/
.venv/
venv/

# ---------------------------- Node / Frontend ----------------------------
frontend/node_modules/       # Only ignore inside frontend
frontend/dist/
frontend/.env

# ---------------------------- Secrets ----------------------------
# Neither Dockerfile currently COPYs the repo root (backend.Dockerfile copies
# backend/, frontend.Dockerfile copies frontend/), so this isn't fixing an
# active leak — it's defense-in-depth against a future `COPY . .` silently
# baking real secrets into an image, same rationale as frontend/.env above.
.env
# frontend/coverage/ — vitest --coverage HTML/JSON report, a local test
# artifact `COPY frontend/ .` would otherwise bake into both the `dev` and
# `builder` image stages (harmless content, unlike backend/logs/ above, but
# still unnecessary image bloat from a directory that's regenerated by
# every `npm run test:coverage` anyway).
frontend/coverage/
npm-debug.log
yarn-error.log
pnpm-debug.log

# ---------------------------- Docker ----------------------------
.dockerignore                # Don't include this file inside the image
.git
.gitignore

# ---------------------------- General ----------------------------
.DS_Store
*.swp
