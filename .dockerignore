# ---------------------------- Python / Backend ----------------------------
# **/ prefix is required for these to match at any depth, not just directly
# under the build context root — a bare "__pycache__/" misses nested dirs.
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.sqlite3
*.db
*.log
# backend/logs/ — rotated access-log files (real request data: paths,
# timestamps, correlation IDs). `*.log` above only matches exactly ".log",
# not rotated siblings like access.log.2026-07-19, which were previously
# getting baked into the image via `COPY backend/ .` — a real privacy leak.
backend/logs/
**/*.egg-info/
dist/
build/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.dmypy.json
.coverage
htmlcov/
.venv/
venv/

# ---------------------------- Node / Frontend ----------------------------
frontend/node_modules/       # Only ignore inside frontend
frontend/dist/
frontend/.env

# ---------------------------- Secrets ----------------------------
# Defense-in-depth against a future `COPY . .` baking real secrets into an
# image — neither Dockerfile currently copies the repo root.
.env
# frontend/coverage/ — vitest --coverage report; unnecessary image bloat,
# regenerated by every `npm run test:coverage` anyway.
frontend/coverage/
npm-debug.log
yarn-error.log
pnpm-debug.log

# ---------------------------- Docker ----------------------------
.dockerignore                # Don't include this file inside the image
.git
.gitignore

# ---------------------------- General ----------------------------
.DS_Store
*.swp
