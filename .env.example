# ---------------------------- App Config ----------------------------
# Base URL for backend accessed through NGINX reverse proxy
BACKEND_BASE_URL=http://localhost:8000

# Base URL for frontend React app served from NGINX
FRONTEND_BASE_URL=http://localhost:5173

# ---------------------------- Frontend Build Config (production image only) ----------------------------
# Only read by `docker compose -f docker-compose.prod.yml build frontend` (as
# build args — see docker-compose.prod.yml and docker/frontend.Dockerfile).
# The dev frontend container bind-mounts frontend/.env directly instead, so
# these are irrelevant to `docker compose up` (no -f docker-compose.prod.yml).
# Same variables/values as frontend/.env — duplicated here only because
# docker compose reads this root .env for build-arg interpolation in
# docker-compose.prod.yml, not frontend/.env.
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=MysticAuth
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=

# ---------------------------- Database Config ----------------------------
# SQLAlchemy async database URL (For Docker only)
DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@postgres:5432/<db_name>

# SQLAlchemy async database URL (For running locally)
# DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@localhost:5433/<db_name>

# PostgreSQL user
POSTGRES_USER=<db_username>

# PostgreSQL password
POSTGRES_PASSWORD=<db_password>

# PostgreSQL database name
POSTGRES_DB=<db_name>

# ---------------------------- JWT Config ----------------------------
# Secret key for JWT encoding — must be at least 32 characters, the app
# refuses to start otherwise (see docs/security/decisions.md)
SECRET_KEY=<secret_key_here>

# JWT access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT refresh token expiration in minutes
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# JWT signing algorithm
JWT_ALGORITHM=HS256

# Password reset token expiration in minutes
RESET_TOKEN_EXPIRE_MINUTES=60

# ---------------------------- OAuth2 / Gmail Config ----------------------------
# Google OAuth2 client ID
GOOGLE_CLIENT_ID=<your_google_client_id>

# Google OAuth2 client secret
GOOGLE_CLIENT_SECRET=<your_google_client_secret>

# Google OAuth2 redirect URI after authentication
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth2/callback/google

# ---------------------------- Redis Config ----------------------------
# Redis auth password. Blank = no auth (fine for local dev). For any
# deployment that publishes the Redis port or shares a network with
# untrusted services, set a strong password here — docker-compose.yml/
# docker-compose.prod.yml pass this to `redis-server --requirepass`. If
# set, it must also be embedded in REDIS_URL below.
REDIS_PASSWORD=

# Redis connection URL (For Docker only). If REDIS_PASSWORD above is set,
# it must also be embedded here (redis-py and taskiq-redis both
# authenticate via the URL, not a separate setting):
#   REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0

# Redis connection URL (For running locally; Run redis in Docker)
# REDIS_URL=redis://localhost:6380/0

# Default cache TTL in seconds
CACHE_DEFAULT_TTL=300

# ---------------------------- Email / SMTP Config ----------------------------
# Email address used for sending emails (also the SMTP auth username)
FROM_EMAIL=<your_google_email>

# Gmail App password for sending email from above account
GMAIL_APP_PASSWORD=<your_gmail_app_password>

# Contact address shown in email footers and used as the Reply-To header.
# Optional — defaults to FROM_EMAIL if unset.
SUPPORT_EMAIL=<your_support_email>

# SMTP server used by emails/email_sender.py::SMTPEmailSender.
# Optional — default is Gmail's; override to point at another SMTP provider.
# SMTP_HOST=smtp.gmail.com

# SMTP port. Optional — default is 587 (STARTTLS, Gmail's default).
# SMTP_PORT=587

# ---------------------------- App Name Config ----------------------------
# Product name shown in email branding and API responses
APP_NAME=MysticAuth

# ---------------------------- Rate Limiter Config ----------------------------
# Lockout time in seconds after failed login attempts
LOGIN_LOCKOUT_TIME=300

# Maximum allowed failed login attempts before lockout
MAX_FAILED_LOGIN_ATTEMPTS=5

# Lockout time in seconds for a single IP after too many failed logins across any accounts
LOGIN_LOCKOUT_TIME_PER_IP=300

# Maximum failed login attempts from a single IP (across any accounts) before that IP is locked out.
# Higher than MAX_FAILED_LOGIN_ATTEMPTS since one IP can legitimately represent many distinct
# users (NAT/corporate networks) — this exists to catch credential-stuffing/spraying across many
# accounts from one source, not to duplicate the per-account lockout above.
MAX_FAILED_LOGIN_ATTEMPTS_PER_IP=20

# Maximum number of requests per window
MAX_REQUESTS_PER_WINDOW=100

# Duration of request window in seconds
REQUEST_WINDOW_SECONDS=60

# ---------------------------- Logging Config ----------------------------
# Application log level: DEBUG, INFO, WARNING, ERROR.
# Optional — defaults to INFO.
LOG_LEVEL=INFO

# ---------------------------- Environment Config ----------------------------
# "development" or "production".
# Optional — defaults to development.
# Production disables /docs, /redoc, and /openapi.json to reduce attack surface.
ENVIRONMENT=development

# ---------------------------- Reverse Proxy Config ----------------------------
# Comma-separated IP addresses of trusted reverse proxies (e.g. nginx).
# Leave empty unless a real proxy sits in front of FastAPI.
# Only trusted proxies can provide X-Forwarded-For client IP information.
TRUSTED_PROXY_IPS=

# ---------------------------- Error Monitoring Config ----------------------------
# Optional. Sentry-protocol DSN for the backend (works with Sentry itself,
# or a self-hosted Sentry-SDK-compatible server — see
# docs/error-monitoring/overview.md for the self-hosted Bugsink setup this
# template documents). Leave blank to disable entirely — no Sentry SDK call
# is ever made when unset.
SENTRY_DSN=

# Optional. Tag reported alongside every event (e.g. "production").
# Falls back to ENVIRONMENT above if unset.
SENTRY_ENVIRONMENT=

# The following BUGSINK_* variables configure the optional, opt-in
# self-hosted Bugsink service in docker-compose.yml/docker-compose.prod.yml
# (docker compose --profile monitoring up) — they are read directly by that
# container, not by the backend/frontend's own Settings. See
# docs/error-monitoring/overview.md for the full setup walkthrough
# (Bugsink's project DSN, generated after first login, is what actually
# goes into SENTRY_DSN above).

# Django's own secret key for the Bugsink service — distinct from this
# app's own SECRET_KEY above, unrelated purpose. Generate with, e.g.,
# `openssl rand -base64 50`.
BUGSINK_SECRET_KEY=<bugsink_secret_key_here>

# One-time admin login email created on Bugsink's first startup.
BUGSINK_SUPERUSER_EMAIL=<your_email>

# One-time admin login password created on Bugsink's first startup.
BUGSINK_SUPERUSER_PASSWORD=<bugsink_admin_password>

# The URL you'll actually open Bugsink's UI at.
BUGSINK_BASE_URL=http://localhost:8010
