# ---------------------------- App Config ----------------------------
# URL where the backend is reachable
BACKEND_BASE_URL=http://localhost:8000

# URL where the frontend is reachable
FRONTEND_BASE_URL=http://localhost:5173

# ---------------------------- Frontend Config ----------------------------
# Used by the frontend under `docker compose up` (dev and prod) — no need to
# also fill in frontend/.env.example unless you're running the frontend
# locally with `npm run dev`, outside Docker.
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=MysticAuth
# Leave blank — auto-filled once Bugsink starts (see SENTRY_DSN below)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=

# ---------------------------- Database Config ----------------------------
# Prefilled so `docker compose up` works out of the box — change the
# password (and keep DATABASE_URL in sync) before using this for anything
# beyond local dev.
# Used when running via Docker
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/mystic_auth

# Used when running the backend locally instead of in Docker
# DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@localhost:5433/mystic_auth

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mystic_auth

# ---------------------------- JWT Config ----------------------------
# Prefilled with an obviously-fake placeholder so the app boots out of the
# box — generate your own before using this for anything beyond local dev
# (e.g. `openssl rand -base64 32`). Must be at least 32 characters.
SECRET_KEY=change_me_in_production_generate_your_own_random_32plus_char_key

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200
JWT_ALGORITHM=HS256
RESET_TOKEN_EXPIRE_MINUTES=60

# ---------------------------- OAuth2 / Gmail Config ----------------------------
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth2/callback/google

# ---------------------------- Redis Config ----------------------------
# Leave blank for local dev. Set a strong password for any deployment
# reachable outside your machine, and mirror it into REDIS_URL below.
REDIS_PASSWORD=

# Used when running via Docker. If REDIS_PASSWORD is set, include it here too:
#   REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0

# Used when running the backend locally (Redis still runs in Docker)
# REDIS_URL=redis://localhost:6380/0

CACHE_DEFAULT_TTL=300

# ---------------------------- Email / SMTP Config ----------------------------
# Address emails are sent from (also the SMTP login username)
FROM_EMAIL=<your_google_email>

# Gmail App Password for the account above
GMAIL_APP_PASSWORD=<your_gmail_app_password>

# Reply-To address shown in email footers. Optional — defaults to FROM_EMAIL.
SUPPORT_EMAIL=<your_support_email>

# Optional — only needed if not using Gmail's SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ---------------------------- App Name Config ----------------------------
# Product name shown in emails and API responses
APP_NAME=MysticAuth

# ---------------------------- Rate Limiter Config ----------------------------
# How long (seconds) an account is locked out after too many failed logins
LOGIN_LOCKOUT_TIME=300

# Failed login attempts allowed before an account is locked out
MAX_FAILED_LOGIN_ATTEMPTS=5

# How long (seconds) an IP is locked out after too many failed logins across any accounts
LOGIN_LOCKOUT_TIME_PER_IP=300

# Failed login attempts allowed from one IP (across any accounts) before it's locked out.
# Set higher than MAX_FAILED_LOGIN_ATTEMPTS since one IP can be many real users (e.g. office wifi).
MAX_FAILED_LOGIN_ATTEMPTS_PER_IP=20

# General API rate limit: max requests per window, per window duration (seconds)
MAX_REQUESTS_PER_WINDOW=100
REQUEST_WINDOW_SECONDS=60

# ---------------------------- Logging Config ----------------------------
# DEBUG, INFO, WARNING, or ERROR. Optional — defaults to INFO.
LOG_LEVEL=INFO

# ---------------------------- Environment Config ----------------------------
# "development" or "production". Optional — defaults to development.
# Production hides /docs, /redoc, and /openapi.json.
ENVIRONMENT=development

# ---------------------------- Reverse Proxy Config ----------------------------
# Comma-separated IPs of trusted reverse proxies (e.g. nginx). Leave empty
# unless a real proxy sits in front of the backend.
TRUSTED_PROXY_IPS=

# ---------------------------- Error Monitoring Config ----------------------------
# Leave blank to disable error monitoring entirely. Under `docker compose up`
# this gets auto-filled once Bugsink (self-hosted, starts by default) creates
# its project — see docs/mystic_auth/error-monitoring/overview.md for details.
SENTRY_DSN=

# Optional tag shown on every reported error (e.g. "production").
# Falls back to ENVIRONMENT above if unset.
SENTRY_ENVIRONMENT=

# The BUGSINK_* settings below configure the self-hosted Bugsink service,
# which starts by default with `docker compose up`. See
# docs/mystic_auth/error-monitoring/overview.md for the full setup walkthrough.

# Bugsink's own secret key (unrelated to this app's SECRET_KEY above).
# Prefilled so it boots out of the box — generate your own real value
# (`openssl rand -base64 50`) before using this for anything beyond local dev.
BUGSINK_SECRET_KEY=change_me_in_production_generate_your_own_random_50plus_char_key

# Admin login created the first time Bugsink starts. Just a local login for
# Bugsink's own UI (never emailed to, no real account needed) — prefilled so
# it boots out of the box; change it to your own if you want.
BUGSINK_SUPERUSER_EMAIL=admin@example.com
BUGSINK_SUPERUSER_PASSWORD=change_me_in_production

# URL where you'll open Bugsink's UI
BUGSINK_BASE_URL=http://localhost:8010
