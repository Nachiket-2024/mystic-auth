# ---------------------------- Application ----------------------------
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# ---------------------------- Database ----------------------------
# Docker service hostname; swap to localhost when running the backend outside Docker
DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@postgres:5432/<db_name>
# DATABASE_URL=postgresql+asyncpg://<db_username>:<db_password>@localhost:5433/<db_name>

POSTGRES_USER=<db_username>
POSTGRES_PASSWORD=<db_password>
POSTGRES_DB=<db_name>

# ---------------------------- JWT & Tokens ----------------------------
SECRET_KEY=<secret_key_here>
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=43200
JWT_ALGORITHM=HS256
RESET_TOKEN_EXPIRE_MINUTES=60

# ---------------------------- OAuth2 ----------------------------
GOOGLE_CLIENT_ID=<your_google_client_id>
GOOGLE_CLIENT_SECRET=<your_google_client_secret>
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth2/callback/google

# ---------------------------- Redis & Caching ----------------------------
# Leave blank for no Redis auth (fine for local dev). For any deployment that
# publishes the Redis port or shares a network with untrusted services, set a
# strong password here — docker-compose.yml/docker-compose.prod.yml pass this
# to `redis-server --requirepass`.
REDIS_PASSWORD=

# Docker service hostname; swap to localhost when running Redis outside Docker.
# If REDIS_PASSWORD above is set, it must also be embedded here (redis-py and
# taskiq-redis both authenticate via the URL, not a separate setting):
#   REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://localhost:6380/0

CACHE_DEFAULT_TTL=300

# ---------------------------- Email ----------------------------
FROM_EMAIL=<your_google_email>
GMAIL_APP_PASSWORD=<your_gmail_app_password>

# Contact address shown in email footers and used as the Reply-To header.
# Optional — defaults to FROM_EMAIL if unset.
SUPPORT_EMAIL=<your_support_email>

# SMTP server used by emails/email_sender.py::SMTPEmailSender.
# Optional — default is Gmail's; override to point at another SMTP provider.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Product name shown in email templates and API responses.
APP_NAME=MysticAuth

# ---------------------------- Login Protection ----------------------------
LOGIN_LOCKOUT_TIME=300
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_TIME_PER_IP=300

# Higher than MAX_FAILED_LOGIN_ATTEMPTS since one IP can legitimately represent many users.
# Used to detect credential stuffing/spraying from a single source.
MAX_FAILED_LOGIN_ATTEMPTS_PER_IP=20

# ---------------------------- Rate Limiting ----------------------------
MAX_REQUESTS_PER_WINDOW=100
REQUEST_WINDOW_SECONDS=60

# ---------------------------- Logging ----------------------------
# DEBUG, INFO, WARNING, ERROR.
# Optional — defaults to INFO.
LOG_LEVEL=INFO

# ---------------------------- Environment ----------------------------
# "development" or "production".
# Optional — defaults to development.
# Production disables /docs, /redoc, and /openapi.json to reduce attack surface.
ENVIRONMENT=development

# ---------------------------- Reverse Proxy ----------------------------
# Comma-separated IP addresses of trusted reverse proxies (e.g. nginx).
# Leave empty unless a real proxy sits in front of FastAPI.
# Only trusted proxies can provide X-Forwarded-For client IP information.
TRUSTED_PROXY_IPS=